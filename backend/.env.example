# ==========================================================
# Configuração do Backend (FastAPI)
# Copie este arquivo para .env e ajuste os valores.
# NUNCA comite o arquivo .env real.
# ==========================================================

APP_NAME=ToDo AFL

# Ambiente: development | production.
# Em production o backend NUNCA expõe link/OTP na resposta (falha fechada) e
# recusa subir sem SMTP ou com JWT_SECRET fraco.
ENVIRONMENT=development

# Banco de dados (SQLite local por padrão)
DATABASE_URL=sqlite:///./app.db

# --- Sessão (JWT emitido pelo backend após confirmar link/OTP no modo local) ---
# Gere um valor forte em produção (ex.: openssl rand -hex 32).
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Magic link / OTP (login passwordless do modo local) ---
MAGIC_LINK_EXPIRE_MINUTES=15
OTP_MAX_ATTEMPTS=5
# URL pública do backend, usada para montar o link do email.
# Em dev pode deixar vazio (será derivada do request).
BACKEND_PUBLIC_URL=http://localhost:8000

# Em DEV, devolve link/OTP na resposta mesmo com SMTP ativo (atalho de teste na
# tela). Ignorado em produção (lá nunca expõe). Padrão: true.
SHOW_DEV_LOGIN_CODES=true

# --- SMTP (envio de email via Brevo) ---
# Sem SMTP_USER/SMTP_PASSWORD o backend opera em "modo dev": não envia email e
# devolve link + código OTP na resposta da API (para testes locais).
# No Brevo: SMTP_USER é o login SMTP e SMTP_PASSWORD é a chave SMTP (master key).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@seudominio.com
SMTP_FROM_NAME=ToDo AFL
SMTP_USE_TLS=true

# --- Supabase (modo "Python Backend + Supabase Auth") ---
# Validação via JWKS (chave pública ES256 — sistema novo "JWT Signing Keys").
# Não precisa de nenhum segredo da Supabase no backend.
SUPABASE_URL=
# Chave pública (publishable sb_publishable_... ou anon legada).
# Usada pelo backend no callback cross-device para verificar o token_hash.
SUPABASE_PUBLISHABLE_KEY=
# Issuer do JWT: https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_ISSUER=
# JWKS (chaves públicas do projeto):
# https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated

# CORS: URL do frontend autorizado a chamar a API
FRONTEND_URL=http://localhost:3000

# --- Redis (opcional) ---
# Vazio = desativado (login tokens caem no banco; sem rate limit; realtime
# single-process). Defina para acelerar tokens efêmeros, ligar rate limit e o
# realtime distribuído (Pub/Sub).
REDIS_URL=
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=60
