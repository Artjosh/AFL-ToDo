# ==========================================================
# Configuração do Frontend (Next.js)
# Copie para .env (ou .env.local) e ajuste os valores.
# NUNCA comite o arquivo .env real.
# ==========================================================

# URL do backend Python (FastAPI).
# Usada (a) pelo navegador só para o WebSocket de realtime e (b) pelo servidor
# do Next (BFF) como destino do proxy /api/py/* (quando BACKEND_INTERNAL_URL não
# está definido). As demais chamadas do browser passam pelo próprio Next.
NEXT_PUBLIC_API_URL=http://localhost:8000

# (Opcional) URL INTERNA do backend, usada só pelo servidor do Next para o proxy
# BFF. Útil em Docker (ex.: http://backend:8000). Se vazio, usa NEXT_PUBLIC_API_URL.
# BACKEND_INTERNAL_URL=http://localhost:8000

# --- Supabase (apenas para o modo "Python Backend + Supabase Auth") ---
# Deixe em branco para usar somente o modo local (magic link do backend Python).
# A Supabase é usada SOMENTE para autenticação (sem tabelas/ORM).
NEXT_PUBLIC_SUPABASE_URL=
# Chave pública nova (aba Connect / API Keys -> "Publishable key", formato sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# (Opcional/legado) anon key — usada só como fallback se a publishable não existir.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
